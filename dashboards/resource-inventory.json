      {
        "type": "row",
        "id": "row-host",
        "name": "主机",
        "collapsed": false,
        "layout": {
          "h": 1,
          "w": 24,
          "x": 0,
          "y": 0,
          "i": "row-host",
          "isResizable": false
        }
      },
      {
        "type": "table",
        "id": "tbl-host",
        "name": "主机清单",
        "version": "3.0.0",
        "datasourceCate": "prometheus",
        "datasourceValue": 1,
        "layout": {
          "h": 8,
          "w": 24,
          "x": 0,
          "y": 1,
          "i": "tbl-host",
          "isResizable": true
        },
        "targets": [
          {
            "refId": "A",
            "expr": "mem_available_percent",
            "legend": "状态",
            "instant": false,
            "maxDataPoints": 240
          }
        ],
        "custom": {
          "showHeader": true,
          "calc": "lastNotNull",
          "colorMode": "background",
          "displayMode": "labelValuesToRows",
          "aggrDimension": [
            "ident"
          ],
          "sortColumn": "ident",
          "sortOrder": "ascend"
        },
        "options": {
          "standardOptions": {}
        },
        "overrides": [
          {
            "matcher": {
              "id": "byFrameRefID",
              "value": "A"
            },
            "properties": {
              "valueMappings": [
                {
                  "type": "range",
                  "match": {
                    "from": 0.5
                  },
                  "result": {
                    "text": "在线",
                    "color": "rgba(63,196,83,1)"
                  }
                },
                {
                  "type": "range",
                  "match": {
                    "to": 0.5
                  },
                  "result": {
                    "text": "离线",
                    "color": "rgba(250,6,6,1)"
                  }
                }
              ]
            }
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "renameByName": {
                "ident": "主机",
                "A": "状态"
              }
            }
          }
        ],
        "maxPerRow": 4
      },
