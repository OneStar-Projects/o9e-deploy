# ──────────────────────────────────────────────────────────────
# n9e 单机部署 — 环境变量
# 复制为 .env 后修改密码和域名;.env 已被仓库 .gitignore 排除。
# ──────────────────────────────────────────────────────────────

# ─── 镜像 tag ─────────────────────────────────────────────
# 镜像完整名:fuqiangleon/o9e:${O9E_TAG}
#   默认 latest(滚动,部署侧 docker compose pull 拿最新)
#   生产想锁版本就改成 ci-42 / 1.0.5 等具体 tag,避免 latest 漂移
O9E_TAG=latest

# ─── 对外端口 ─────────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443
# ibex RPC,categraf 反向连接;若 categraf 都在同内网,改为 127.0.0.1:20090 不外暴
IBEX_RPC_PORT=20090

# ─── 域名(用于 README 提示;nginx 模板用 server_name _ 通配)──
N9E_DOMAIN=o9e.example.com

# ─── 数据库密码(initsql 建库时即生效)──────────────────────
MYSQL_ROOT_PASSWORD=please-change-me
N9E_DB_USER=root
N9E_DB_PASSWORD=please-change-me

# ─── Redis 密码 ───────────────────────────────────────────────
REDIS_PASSWORD=please-change-me

# ─── VM 保留周期(单位:月)──────────────────────────────────
VM_RETENTION=3

# ─── Scanopy(网络拓扑发现服务)────────────────────────────────
# 镜像走官方 ghcr.io/scanopy/scanopy/{server,daemon},compose 里写死,无需配置。
# 国内拉 ghcr.io 慢的话需要先 docker save / load,或配 ghcr proxy。

# scanopy 后端 PostgreSQL 密码(独立于 n9e 的 mysql)
SCANOPY_POSTGRES_PASSWORD=please-change-me

# 部署后跑 ./scanopy-bootstrap.sh 自动完成:
#   1. POST /api/auth/setup     (用 ORG_NAME + NETWORK_NAME)
#   2. POST /api/auth/register  (用 ADMIN_EMAIL + ADMIN_PASSWORD)
#   3. login → 创建并启用 User API Key (用 KEY_NAME)
#   4. 写回下面 SCANOPY_TOKEN + 重启 n9e

# scanopy 管理员账号(scanopy UI 登录也用这个)
SCANOPY_ADMIN_EMAIL=admin@o9e.local
SCANOPY_ADMIN_PASSWORD=please-change-me

# scanopy 多租户的组织名(显示在 scanopy UI 上)
SCANOPY_ORG_NAME=o9e

# scanopy 第一次 setup 时创建的默认网络名(出现在网络列表)
SCANOPY_NETWORK_NAME=default

# n9e 调 scanopy 用的 API Key 名(可定位/审计用,不影响功能)
SCANOPY_KEY_NAME=n9e-integration

# n9e 调 scanopy 时带的 Bearer token(scp_u_ 开头)。
# 留空交给 scanopy-bootstrap.sh 写;手工填的话也可以,但要确保 key is_enabled=true。
SCANOPY_TOKEN=

# scanopy 注册控制(生产强烈建议锁掉,防止任何人自助注册新组织/账号):
#   false  → 默认,允许 POST /api/auth/register;首次部署 bootstrap 需要此项 false
#   true   → 禁用自助注册,新用户必须由 admin 通过 POST /api/v1/invites 邀请加入现 org
#
# 建议流程:首次部署保持 false → 跑 ./scanopy-bootstrap.sh 创 admin 和 key → 然后:
#   sed -i 's/^SCANOPY_DISABLE_REGISTRATION=.*/SCANOPY_DISABLE_REGISTRATION=true/' .env
#   docker compose up -d scanopy   # 重建容器吃新 env
SCANOPY_DISABLE_REGISTRATION=false

# ─── topo-studio(网络拓扑独立服务)──────────────────────────────
# n9e 反代 /api/topo-studio/* 与 /topo-studio/* 到 topo-studio 容器,带此 Bearer。
# init-env.sh 自动生成;留空则 topo-studio 不校验 token。
TOPO_API_TOKEN=

# ─── cfgsync 秘钥库 master key ─────────────────────────────────
# AES-256 master key(64 hex),加密存 cfgsync secret(如 SNMP 团体名等)。
# n9e 进程从此 env 读;留空则「新建秘钥」报 "秘钥库未初始化"。init-env.sh 自动生成。
# ⚠ 务必备份:一旦建过秘钥,丢失/变更此 key → DB 里所有 cfgsync 密文永久解不开。
N9E_SECRET_MASTER_KEY=
